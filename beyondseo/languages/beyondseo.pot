#: app/src/Domain/Integrations/WordPress/Seo/Entities/Optimiser/Base/Enums/Suggestion.php:359
#, php-format
msgid "Your meta description is within the acceptable range but could be improved. Aim for a length between %1$d and %2$d characters to enhance click-through rates."
msgstr ""

#: app/src/Domain/Integrations/WordPress/Seo/Entities/Optimiser/Base/Enums/Suggestion.php:362
msgid "Slightly Short Meta Description"
msgstr ""

