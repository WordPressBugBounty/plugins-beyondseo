{
    "name": "beyondseo/beyondseo",
    "description": "Plugin is free software: you can redistribute it and/or modify\n it under the terms of the GNU General Public License as published by\n the Free Software Foundation, either version 2 of the License or\n any later version.\n\n Plugin is distributed in the hope that it will be useful,\n but WITHOUT ANY WARRANTY; without even the implied warranty of\n MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE. See the\n GNU General Public License for more details.\n\n You should have received a copy of the GNU General Public License\n along with plugin. If not, see https://www.rankingcoach.com/en-us/wordpress.",
    "require": {
        "php": ">=8.0",
        "ext-ctype": "*",
        "ext-dom": "*",
        "ext-gd": "*",
        "ext-iconv": "*",
        "ext-libxml": "*",
        "ext-openssl": "*",
        "ext-zlib": "*",
        "ext-json": "*",
        "ext-curl": "*",
        "illuminate/view": "^8.0",
        "illuminate/support": "^8.0",
        "beberlei/doctrineextensions": "^1.3",
        "doctrine/doctrine-bundle": "^2.5",
        "doctrine/orm": "2.*",
        "doctrine/collections": "1.8.0",
        "doctrine/instantiator": "2.0.0",
        "dragonmantank/cron-expression": "^3.3",
        "firebase/php-jwt": "^6.3",
        "guzzlehttp/guzzle": "^7.5",
        "mgamadeus/ddd": "2.4.17",
        "react/child-process": "^0.6.5",
        "react/event-loop": "^1.5",
        "sensio/framework-extra-bundle": "*",
        "symfony/expression-language": "6.0.*",
        "symfony/framework-bundle": "6.0.*",
        "symfony/http-client": "6.0.*",
        "symfony/messenger": "6.0.*",
        "symfony/monolog-bundle": "^3.8.0",
        "symfony/process": "6.0.*",
        "symfony/proxy-manager-bridge": "6.0.*",
        "symfony/runtime": "6.0.*",
        "symfony/security-bundle": "6.0.*",
        "symfony/validator": "6.0.*",
        "symfony/yaml": "6.0.*",
        "symfony/property-info": "6.0.*",
        "symfony/http-foundation": "6.0.*",
        "symfony/property-access": "6.0.*",
        "symfony/var-exporter": "6.0.*",
        "symfony/var-dumper": "6.0.*",
        "symfony/string": "6.0.*",
        "symfony/security-http": "6.0.*",
        "symfony/security-csrf": "6.0.*",
        "symfony/security-core": "6.0.*",
        "symfony/routing": "6.0.*",
        "symfony/password-hasher": "6.0.*",
        "symfony/monolog-bridge": "6.0.*",
        "symfony/filesystem": "6.0.*",
        "symfony/event-dispatcher": "6.0.*",
        "symfony/error-handler": "6.0.*",
        "symfony/cache": "6.0.*",
        "symfony/doctrine-bridge": "6.0.*",
        "symfony/workflow": "6.0.*",
        "symfony/serializer": "6.0.*",
        "symfony/dependency-injection": "6.0.*",
        "symfony/config": "6.1.*",
        "laminas/laminas-code": "4.5.2"
    },
    "config": {
        "platform": {
            "php": "8.0.2"
        },
        "allow-plugins": {
            "composer/package-versions-deprecated": true,
            "symfony/runtime": true
        },
        "optimize-autoloader": true
    },
    "autoload": {
        "psr-4": {
            "RankingCoach\\Inc\\": "../inc/",
            "BeyondSEO\\": "src/"
        },
        "exclude-from-classmap": [
            "../inc/Core/Plugin/mu/*"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "RankingCoach\\Tools\\": "../tools/"
        },
        "files": [],
        "exclude-from-classmap": [
        ]
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "prefix-namespaces": [
          "sh -c 'test -f ./bin/strauss.phar || curl -o bin/strauss.phar -L -C - https://github.com/BrianHenryIE/strauss/releases/latest/download/strauss.phar'",
          "@php bin/strauss.phar",
          "@composer dump-autoload"
        ],
        "post-install-cmd": [

        ],
        "post-update-cmd": [

        ],
        "post-autoload-dump": [

        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "*",
            "no-recipe-lock": true
        },
      "strauss": {
        "target_directory": "vendor_prefixed",
        "namespace_prefix": "BeyondSEODeps\\",
        "classmap_prefix": "BeondSEODeps_",
        "constant_prefix": "BEYONDSEO_DEPS_",
        "packages": [
        ],
        "update_call_sites": false,
        "include_root_autoload": true,
        "override_autoload": {
        },
        "exclude_from_copy": {
          "packages": [
          ],
          "namespaces": [
          ],
          "file_patterns": [
          ]
        },
        "exclude_from_prefix": {
          "packages": [
            "psr/*",
            "psr/cache",
            "psr/container",
            "psr/event-dispatcher",
            "psr/http-factory",
            "psr/http-message",
            "psr/http-client",
            "psr/log",
            "psr/simple-cache"
          ],
          "namespaces": [
            "RankingCoach\\Inc\\",
            "RankingCoach\\Tools\\",
            "BeyondSEO\\",
            "Psr\\",
            "Psr",
            "Psr\\Http\\Client\\",
            "Psr\\Http\\Client",
            "Psr\\Http\\Message\\",
            "Psr\\Http\\Message"
          ],
          "file_patterns": [
          ]
        },
        "namespace_replacement_patterns" : {
        },
        "delete_vendor_packages": true,
        "delete_vendor_files": false
      }
    },
  "repositories": [
    {
      "type": "path",
      "url": "../shell/packages/ddd",
      "options": { "symlink": false }
    }
  ],
  "require-dev": {
    "symfony/redis-messenger": "6.0.*",
    "amphp/parallel": "1.*",
    "symfony/dotenv": "6.0.*",
    "predis/predis": "2.*",
    "symfony/amqp-messenger": "6.0.*",
    "ezyang/htmlpurifier": "^4.17",
    "symfony/console": "6.0.*",
    "symfony/form": "6.0.*",
    "symfony/mime": "6.0.*",
    "symfony/translation" : "6.0.*",
    "twig/twig": "^3.22"
  },
  "replace": {
      "mockery/mockery": "*",
      "giggsey/libphonenumber": "*",
      "nesbot/carbon": "*"
  }
}
